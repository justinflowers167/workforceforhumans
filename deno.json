{
  "tasks": {
    "test": "deno test --no-check --allow-net --allow-env --allow-read supabase/functions/",
    "test:cov": "deno test --no-check --allow-net --allow-env --allow-read --coverage=cov supabase/functions/ && deno coverage cov --lcov > cov.lcov"
  },
  "imports": {
    "std/assert": "https://deno.land/std@0.224.0/assert/mod.ts",
    "@supabase/supabase-js": "https://esm.sh/@supabase/supabase-js@2?target=deno",
    "@anthropic-ai/sdk": "https://esm.sh/@anthropic-ai/sdk@0.32.1?target=deno"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": false,
    "semiColons": true
  },
  "exclude": [
    "cov/",
    "cov.lcov"
  ]
}
